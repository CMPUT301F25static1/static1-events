@startuml

' ============================================================================
' VIEW LAYER
' ============================================================================

package "View Layer" {

  ' --------------------------------------------------------------------------
  ' Activities
  ' --------------------------------------------------------------------------
  package "Activities" {

    class MainActivity {
      - binding: ActivityMainBinding
      - eventRepo: EventRepository
      - qrScanLauncher: ActivityResultLauncher
      - navController: NavController
      --
      + onCreate()
      + onOptionsItemSelected()
      + openEventDetailsWithQrCode()
    }

    note top of MainActivity
      - Main entry point of the app
      - Handles navigation and QR scanning
      - Uses ViewModelProvider for ViewModels
    end note

    class QrScanActivity {
      - previewView: PreviewView
      - cameraExecutor: ExecutorService
      - scanned: boolean
      --
      + onCreate()
      + startCamera()
      + processBarcodes()
    }

    note "QR Code Integration" as QRNote
    QRNote .. MainActivity
    QRNote .. QrScanActivity

    note right of QRNote
      Custom URI scheme: {bundleId}://events?id={eventId}
      ML Kit Barcode scanning for QR processing
      Camera permissions handled automatically
      Returns to MainActivity with result
    end note
  }

  ' --------------------------------------------------------------------------
  ' Fragments
  ' --------------------------------------------------------------------------
  package "Fragments" {

    class MyEventsFragment {
      + onCreateView()
    }

    class EventDetailsFragment {
      - viewModel: EventDetailsViewModel
      - currentEvent: Event
      - UI elements
      --
      + newInstance()
      + onCreateView()
      - setupRecyclerViews()
      - loadEventData()
      - observeData()
    }
  }

  ' --------------------------------------------------------------------------
  ' Adapters
  ' --------------------------------------------------------------------------
  package "Adapters" {

    class EventAdapter {
      - items: List<Event>
      - onEventClickListener
      --
      + submitList()
      + bind()
    }

    class EntrantAdapter {
      - entrants: List<Profile>
      - listType: ListType
      --
      + updateData()
      + bind()
    }

    class WaitlistEntryAdapter {
      - entries: List<WaitlistEntry>
      - onEntryClickListener
      --
      + submitList()
      + bind()
    }

    class NotificationsAdapter {
      - items: List<AppNotification>
      --
      + submit()
    }
  }
}

' ============================================================================
' VIEWMODEL LAYER
' ============================================================================

package "ViewModel Layer" {

  class EventDetailsViewModel {
    - eventRepository: EventRepository
    - profileRepository: ProfileRepository
    - event: MutableLiveData<Event>
    - waitingList: MutableLiveData<List<Profile>>
    - invitedList: MutableLiveData<List<Profile>>
    - enrolledList: MutableLiveData<List<Profile>>
    --
    + getEvent()
    + setEvent()
    + loadEventEntrants()
    + removeFromInvitedList()
    + getWaitingList()
    + getInvitedList()
    + getEnrolledList()
  }

  class NotificationsViewModel {
    - repo: NotificationRepository
    - inbox: MutableLiveData<List<AppNotification>>
    - error: MutableLiveData<String>
    --
    + getInbox()
    + start()
    + stop()
  }

  class SendNotificationViewModel {
    - repo: NotificationRepository
    - sending: MutableLiveData<Boolean>
    - error: MutableLiveData<String>
    - success: MutableLiveData<Boolean>
    --
    + parseUids()
    + send()
  }

  class CreateEventViewModel {
    - event: MutableLiveData<Event>
    - imageUri: MutableLiveData<Uri>
    - validationError: MutableLiveData<String>
    - eventsRepository: EventRepository
    --
    + getEvent()
    + setImageUri()
    + submit()
    - uploadImage()
  }
}

' ============================================================================
' CONTROLLER LAYER
' ============================================================================

package "Controller Layer" {

  class WaitlistController {
    - db: FirebaseFirestore
    - repository: WaitlistEntryRepository
    - event: Event
    --
    + signup()
    + leaveWaitlist()
    + acceptInvite()
    - doAcceptInTransaction()
  }

  note right of WaitlistController
    Three participant states:
    - Waiting: On waitlist
    - Invited: Can accept/decline
    - Enrolled: Accepted invitation

    Transactional updates for data consistency
  end note

  class ProfileController {
    - authManager: AuthManager
    - profileRepository: ProfileRepository
    - fragmentManager: FragmentManager
    --
    + loadInitialProfile()
    + loadProfile()
    + uploadProfile()
    + showProfileView()
    + showCreateProfile()
  }
}

' ============================================================================
' REPOSITORY LAYER
' ============================================================================

package "Repository Layer" {

  class EventRepository {
    - db: FirebaseFirestore
    - eventsRef: CollectionReference
    --
    + addEvent()
    + updateEvent()
    + deleteEvent()
    + getEventById()
    + fetchAllEvents()
    + fetchEventsByOrganizerId()
  }

  class NotificationRepository {
    - db: FirebaseFirestore
    --
    + listenToUserInbox()
    + sendToUser()
    + sendToUids()
    + extractUids()
  }

  note right of NotificationRepository
    Real-time inbox using Firestore listeners
    Multiple audience types:
    - Selected, Waitlist, Cancelled, Chosen

    Auto-cleanup on ViewModel clearance
  end note

  class ProfileRepository {
    - db: FirebaseFirestore
    - profilesRef: CollectionReference
    --
    + addProfile()
    + updateProfile()
    + deleteProfile()
    + getProfileById()
  }

  class WaitlistEntryRepository {
    - db: FirebaseFirestore
    --
    + addToWaitlist()
    + updateWaitlist()
    + removeFromWaitlist()
  }
}

' ============================================================================
' SERVICE LAYER
' ============================================================================

package "Service Layer" {

  class AuthManager {
    - auth: FirebaseAuth
    --
    + ensureSignedIn()
    + getUserId()
  }

  note right of AuthManager
    Anonymous authentication by default
    Auto-signs in users on app start
    No profile required initially
    UID used for data partitioning
  end note

  class DateUtils {
    + formatDateRange()
    + formatTimeRange()
    + formatDateTime()
  }

  class QrUtils {
    ' QR utility methods
    + generateQrCode()
  }

  class StorageManager {
    + uploadImage()
    + deleteImage()
  }

  note right of StorageManager
    Multi-step validation:
    - Required fields check
    - Date logic validation
    - Image upload to Firebase Storage
    - Automatic organizer ID assignment
  end note
}

' ============================================================================
' APPLICATION
' ============================================================================

package "Application" {

  class MainApplication {
    - authManager: AuthManager
    --
    + onCreate()
    + getAuthManager()
  }
}

' ============================================================================
' ENTITIES
' ============================================================================

package "Entities" <<Database>> {

  class Event {
    - eventId: String
    - title: String
    - description: String
    - location: String
    - capacity: int
    - organizerId: String
    - eventStartDate: Date
    - eventEndDate: Date
    - registrationCloses: Date
    --
    + getters/setters
  }

  class Profile {
    - uid: String
    - fullName: String
    --
    + getters/setters
  }

  class AppNotification {
    - eventId: String
    - senderId: String
    - title: String
    - message: String
    - type: String
    - createdAt: Date
    - read: boolean
    --
    + getters/setters
  }

  class WaitlistEntry {
    - profile: Profile
    - status: String
    - joinedAt: Date
    --
    + getters/setters
  }
}

' ============================================================================
' RELATIONSHIPS
' ============================================================================

' View to ViewModel
MainActivity --> EventDetailsViewModel
MainActivity --> NotificationsViewModel
MainActivity --> CreateEventViewModel
QrScanActivity --> EventDetailsViewModel
EventDetailsFragment --> EventDetailsViewModel

' View to Adapter
MyEventsFragment --o EventAdapter
MainActivity --o NotificationsAdapter
EventDetailsFragment --o EntrantAdapter
EventDetailsFragment --o WaitlistEntryAdapter

' ViewModel to Repository/Controller
EventDetailsViewModel --> WaitlistController
EventDetailsViewModel --> EventRepository
EventDetailsViewModel --> ProfileRepository
NotificationsViewModel --> NotificationRepository
SendNotificationViewModel --> NotificationRepository
CreateEventViewModel --> EventRepository
CreateEventViewModel --> StorageManager

' Controller to Repository/Service
WaitlistController --> WaitlistEntryRepository
WaitlistController --> EventRepository
ProfileController --o AuthManager
ProfileController --o ProfileRepository

' Repository to Service
EventRepository --> AuthManager
ProfileRepository --> AuthManager

' Service/Utility Usage
QrScanActivity --> QrUtils
CreateEventViewModel --> DateUtils
MainApplication --* AuthManager

' Repository to Entity
EventRepository --> Event
ProfileRepository --> Profile
NotificationRepository --> AppNotification
WaitlistEntryRepository --> WaitlistEntry

@enduml